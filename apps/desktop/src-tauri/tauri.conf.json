{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbital",
  "version": "0.1.0",
  "identifier": "com.orbital.studyos",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @orbital/client",
    "beforeBuildCommand": "npm run build --workspace @orbital/client",
    "frontendDist": "../../client/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Orbital",
        "width": 1480,
        "height": 960,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": []
  }
}
